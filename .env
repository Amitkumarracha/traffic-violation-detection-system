# Traffic Violation Detection - Environment Variables
# PRODUCTION CONFIGURATION

# ============================================
# API KEYS (Optional - System works without these)
# ============================================

# Google Gemini API Key (for AI verification - OPTIONAL)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# SendGrid API Key (for email notifications - OPTIONAL)
# Get from: https://sendgrid.com/
SENDGRID_API_KEY=

# ============================================
# DATABASE CONFIGURATION
# ============================================

# SQLite (default - works out of the box)
DATABASE_URL=sqlite:///./violations.db

# ============================================
# APPLICATION SETTINGS
# ============================================

APP_NAME=Traffic Violation Detection
APP_VERSION=1.0.0
DEBUG=false

# ============================================
# API SERVER SETTINGS
# ============================================

# 0.0.0.0 = accessible from network (for mobile/RPi)
API_HOST=0.0.0.0
API_PORT=8000

# ============================================
# MODEL SETTINGS
# ============================================

# Confidence threshold (0.75 = 75% confidence required)
MODEL_CONFIDENCE_THRESHOLD=0.75
MAX_VIOLATIONS_TO_STORE=10000

# ============================================
# NOTIFICATIONS (Optional)
# ============================================

NOTIFICATION_EMAIL=
ALERT_ON_VIOLATION=false

# ============================================
# NOTES
# ============================================
# 
# ✅ System is PRODUCTION READY without any API keys
# ✅ API keys are only for optional enhancements:
#    - GEMINI_API_KEY: AI-powered violation verification
#    - SENDGRID_API_KEY: Email alerts
#
# 🚀 To start: python backend/run_server.py
#
