# Traffic Violation Detection - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# API KEYS (Optional but recommended)
# ============================================

# Google Gemini API Key (for AI analysis of violations)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# SendGrid API Key (for email notifications)
# Get your key from: https://sendgrid.com/
SENDGRID_API_KEY=your_sendgrid_api_key_here

# ============================================
# DATABASE CONFIGURATION
# ============================================

# SQLite (default, no setup needed)
DATABASE_URL=sqlite:///./violations.db

# PostgreSQL (production recommended)
# DATABASE_URL=postgresql://user:password@localhost:5432/violations_db

# MySQL
# DATABASE_URL=mysql://user:password@localhost:3306/violations_db

# ============================================
# CLOUD SYNC (Optional - Supabase)
# ============================================

# Supabase Project URL (for cloud backup of violations)
# Get from: https://supabase.com/
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key
SUPABASE_KEY=your_supabase_anon_key_here

# ============================================
# APPLICATION SETTINGS
# ============================================

# Application name
APP_NAME=Traffic Violation Detection

# Application version
APP_VERSION=1.0.0

# Debug mode (set to true only in development)
DEBUG=false

# ============================================
# API SERVER SETTINGS
# ============================================

# Server host (0.0.0.0 = accessible from network)
API_HOST=0.0.0.0

# Server port
API_PORT=8000

# ============================================
# MODEL SETTINGS
# ============================================

# Confidence threshold for detections (0.0 - 1.0)
# 0.75 = 75% confidence required to report violation
MODEL_CONFIDENCE_THRESHOLD=0.75

# Maximum number of violations to store before cleanup
MAX_VIOLATIONS_TO_STORE=10000

# ============================================
# NOTIFICATIONS
# ============================================

# Email address to receive violation alerts
NOTIFICATION_EMAIL=your_email@example.com

# Whether to send alerts (true/false)
ALERT_ON_VIOLATION=true

# ============================================
# NOTES
# ============================================
#
# 1. RENAME THIS FILE:
#    mv .env.example .env
#
# 2. FILL IN YOUR VALUES
#
# 3. NEVER COMMIT .env TO GIT
#    Add to .gitignore:
#    echo ".env" >> .gitignore
#
# 4. FOR PRODUCTION:
#    - Use PostgreSQL instead of SQLite
#    - Enable Supabase for cloud backup
#    - Set DEBUG=false
#    - Use environment-specific secrets manager
#
